# Example: ~/.azure-devops/credentials   (chmod 600, never commit)
# Supports both Azure DevOps Services (cloud) and self-hosted Server.

[default]
org_url     = https://dev.azure.com/your-org
pat         = your-azure-devops-pat-52-chars
api_version = 7.0
project     = MyProject

# Self-hosted Azure DevOps Server example:
[work-server]
org_url     = https://devops.your-company.com/DefaultCollection
pat         = your-server-pat-52-chars
api_version = 5.1                  # Server often needs 5.1
project     = InternalProject
insecure    = false                # set to true ONLY for self-signed certs on trusted internal networks

# Personal account example:
[personal]
org_url     = https://dev.azure.com/your-personal-org
pat         = your-personal-pat
api_version = 7.0

# Get PAT: https://<org-or-server>/_usersSettings/tokens
# Recommended scopes (least privilege):
#   Code (Read & Write), Pull Request Threads (Read & Write),
#   Work Items (Read & Write), Build (Read & Execute)
# Avoid Full access.
#
# Switch profile: /azure-devops --profile work-server pr-list MyRepo
# Or set: AZDO_PROFILE=work-server  (also AZURE_DEVOPS_PROFILE)
