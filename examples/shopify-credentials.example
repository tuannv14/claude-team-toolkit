# Example: ~/.shopify/credentials   (chmod 600, never commit)
# Multi-store AND multi-app profiles for Shopify Admin GraphQL API.
#
# Each profile = one (shop_domain, access_token) pair.
# You can have:
#   - Multiple stores         (one profile per store)
#   - Multiple apps per store (one profile per app, different access_token)
#   - Both at once            (matrix of stores × apps)

# ─────────────────────────────────────────────────────────────
# Pattern 1 — Multi-STORE (one app per store)
# ─────────────────────────────────────────────────────────────

[default]
shop_domain  = your-main-store.myshopify.com
access_token = shpat_main-store-token-32-chars
api_version  = 2026-04

[client_a]
shop_domain  = client-a.myshopify.com
access_token = shpat_client-a-token
api_version  = 2026-04
require_confirm = true                 # prod store

[staging]
shop_domain  = your-staging-store.myshopify.com
access_token = shpat_staging-token
api_version  = 2026-04

# ─────────────────────────────────────────────────────────────
# Pattern 2 — Multi-APP on the same store (least-privilege per app)
# ─────────────────────────────────────────────────────────────
# Use case: separate Custom Apps with different Admin API scopes so each
# team / workflow uses only what it needs. Token leak in one app does not
# affect the others.

[main-products]
shop_domain  = your-main-store.myshopify.com
access_token = shpat_products-app-token        # scopes: read_products, write_products
api_version  = 2026-04

[main-orders]
shop_domain  = your-main-store.myshopify.com
access_token = shpat_orders-app-token          # scopes: read_orders, read_customers
api_version  = 2026-04

[main-inventory]
shop_domain  = your-main-store.myshopify.com
access_token = shpat_inventory-app-token       # scopes: read_inventory, write_inventory
api_version  = 2026-04
require_confirm = true                          # write-capable → confirm gate

[main-marketing]
shop_domain  = your-main-store.myshopify.com
access_token = shpat_marketing-app-token       # scopes: read_customers, read_orders
api_version  = 2026-04

# ─────────────────────────────────────────────────────────────
# Pattern 3 — MATRIX (multiple stores × multiple apps)
# ─────────────────────────────────────────────────────────────
# Recommended naming: <store>-<app-or-purpose>

[store-eu-products]
shop_domain  = eu-store.myshopify.com
access_token = shpat_eu-products-token
api_version  = 2026-04

[store-eu-inventory]
shop_domain  = eu-store.myshopify.com
access_token = shpat_eu-inventory-token
api_version  = 2026-04
require_confirm = true

[store-us-products]
shop_domain  = us-store.myshopify.com
access_token = shpat_us-products-token
api_version  = 2026-04

[store-us-inventory]
shop_domain  = us-store.myshopify.com
access_token = shpat_us-inventory-token
api_version  = 2026-04
require_confirm = true

# ─────────────────────────────────────────────────────────────
# Why multi-app on the same store
# ─────────────────────────────────────────────────────────────
# 1. Least-privilege scopes — leak of marketing app doesn't expose inventory
# 2. Audit separation — Shopify admin shows API calls per app
# 3. Revocation granularity — uninstall one app without breaking others
# 4. Team boundaries — different teams own different apps
# 5. Custom + Public app coexistence — sometimes you need both

# Get access token (Custom App):
#   1. Shopify admin → Settings → Apps and sales channels → Develop apps
#   2. Create custom app → Configure Admin API scopes (LEAST PRIVILEGE)
#   3. Install app → reveal Admin API access token (starts with "shpat_")
#   4. Token shown ONCE at install time — copy immediately
#
# Common scopes by use case (grant only what each app needs):
#   Read products       : read_products
#   Update products     : read_products + write_products
#   Read orders         : read_orders
#   Customers           : read_customers (+ write_customers for updates)
#   Inventory           : read_inventory (+ write_inventory)
#   Draft orders        : read_draft_orders + write_draft_orders
#
# Versioning:
#   Shopify ships a new stable version every quarter (YYYY-MM).
#   Each is supported for 12 months. Bump api_version quarterly.
#   Never use "unstable" in production.
#
# Switch profile per call:
#   /shopify --profile main-products products
#   /shopify --profile main-inventory inventory <variant-id>
#   /shopify --profile store-eu-products products
#
# Switch via env (per shell session):
#   SHOPIFY_PROFILE=main-orders /shopify orders --status open
#
# Set active profile (persists):
#   /shopify profile use main-products
