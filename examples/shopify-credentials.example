# Example: ~/.shopify/credentials   (chmod 600, never commit)
# Multi-store profiles for Shopify Admin GraphQL API.

[default]
shop_domain  = your-store.myshopify.com
access_token = shpat_your-custom-app-access-token-32-chars
api_version  = 2026-04                 # latest stable as of May 2026; bump quarterly

[client_a]
shop_domain  = client-a-store.myshopify.com
access_token = shpat_client-a-access-token
api_version  = 2026-04
require_confirm = true                 # prod store — gate every mutation

[staging]
shop_domain  = your-staging-store.myshopify.com
access_token = shpat_staging-access-token
api_version  = 2026-04

# Get access token (Custom App):
#   1. Shopify admin → Settings → Apps and sales channels → Develop apps
#   2. Create custom app → Configure Admin API scopes (LEAST PRIVILEGE)
#   3. Install app → reveal Admin API access token (starts with "shpat_")
#   4. Token shown ONCE at install time — copy immediately
#
# Recommended scopes by use case:
#   Read products       : read_products
#   Update products     : read_products + write_products
#   Read orders         : read_orders
#   Customers           : read_customers (+ write_customers for updates)
#   Inventory           : read_inventory (+ write_inventory)
#   Draft orders        : read_draft_orders + write_draft_orders
#
# Versioning:
#   Shopify ships a new stable version every quarter (YYYY-MM).
#   Each is supported for 12 months. Bump api_version quarterly.
#   Never use "unstable" in production.
#
# Switch profile: /shopify --profile client_a products
# Or: SHOPIFY_PROFILE=client_a /shopify orders --status open
