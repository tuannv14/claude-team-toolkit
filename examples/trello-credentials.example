# Example: ~/.trello/credentials   (chmod 600, never commit)
# Copy this template to ~/.trello/credentials and fill with your real creds.
# Add as many [profile] sections as you need (one per Trello account).

[default]
key   = your-trello-api-key-32-chars
token = ATTAyour-trello-token-64-chars

[work]
key   = your-work-trello-api-key
token = ATTAyour-work-trello-token

[client_a]
key   = your-client-trello-api-key
token = ATTAyour-client-trello-token

# Get key + token at: https://trello.com/app-key
# Switch profile: /trello --profile work boards   (or set TRELLO_PROFILE=work)
