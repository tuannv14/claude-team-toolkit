# Example env vars for switching profiles per-call without changing active.
# Copy to .env in YOUR project (not this repo) — never commit real .env.
# This file (.env.example) is committed; .env is in .gitignore.

# Switch profile for a single command:
#   TRELLO_PROFILE=work       /trello boards
#   AZDO_PROFILE=work-server  /azure-devops pr-list MyRepo
#   HEROKU_PROFILE=prod       /heroku scale web=3
#   FIREBASE_PROFILE=staging  /firebase rc-get
#   PG_PROFILE=staging        /postgres query "..."
#   SLACK_PROFILE=client      /slack post #releases "..."
#   SENTRY_PROFILE=work       /sentry issues
#   K6_PROFILE=staging        /k6 run tests/load.js

# Aliases (back-compat):
#   AZDO_PROFILE     == AZURE_DEVOPS_PROFILE
#   BA_PROFILE       == BUNDLER_AUDIT_PROFILE
#   RN_PROFILE       == REACT_NATIVE_PROFILE
#   XTC_PROFILE      == XLSX_TESTCASES_PROFILE

# k6 example: target URL + auth header for staging
K6_BASE_URL=https://staging.example.com
K6_AUTH_HEADER=Bearer your-token-here

# RSpec example: which Rails env to test in
RAILS_ENV=test
