# --- CRITICAL: never commit credentials ---
# Credential DATA files (NOT *.sh helpers — see lib/credentials.sh)
**/credentials
**/credentials.json
**/credentials.ini
**/credentials.yml
**/credentials.yaml
**/*.credentials.json
**/*.credentials.ini

# PAT / token files
**/*.pat
**/*.token
**/.*_pat
**/.*_token

# Environment files
.env
.env.*
!.env.example

# Keys, certs, signing material
*.key
*.pem
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
*.p8
id_rsa
id_dsa
id_ecdsa
id_ed25519
*_rsa
*_dsa
*_ecdsa
*_ed25519

# GCP service account keys
*-service-account.json
*-sa.json
gcp-key*.json
firebase-adminsdk-*.json

# Kubernetes
.kube/config
kubeconfig

# Generic secret patterns
**/secrets/
**/*secret*
**/*Secret*

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Claude Code local state
.claude/settings.local.json
.claude/cache/
